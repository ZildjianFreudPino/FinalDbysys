@{
    ViewData["Title"] = "Home Page";
}

<style>
    body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        background: linear-gradient(135deg, #fff7ed, #f8fafc);
        font-family: 'Inter', sans-serif;
        overflow: hidden;
    }

    .login-wrapper {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .glass-card {
        width: 450px;
        background: rgba(255,255,255,0.85);
        backdrop-filter: blur(12px);
        border-radius: 32px;
        padding: 60px 50px;
        text-align: center;
        border: 1px solid rgba(255,255,255,0.3);
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        animation: fadeIn 0.7s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .logo-title {
        font-size: 78px;
        font-weight: 800;
        color: #f59e0b;
        letter-spacing: 2px;
        margin-bottom: 10px;
    }

    .subtitle {
        color: #64748b;
        font-size: 20px;
        margin-bottom: 50px;
    }

    .btn-login {
        background: #f59e0b;
        border: none;
        color: black;
        font-weight: 700;
        font-size: 22px;
        padding: 16px 70px;
        border-radius: 18px;
        transition: 0.25s ease;
        box-shadow: 0 10px 20px rgba(245,158,11,0.25);
    }

        .btn-login:hover {
            background: #fbbf24;
            transform: translateY(-3px) scale(1.03);
            box-shadow: 0 14px 24px rgba(245,158,11,0.35);
            color: black;
        }

    .circle1,
    .circle2 {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        z-index: -1;
    }

    .circle1 {
        width: 300px;
        height: 300px;
        background: rgba(245,158,11,0.15);
        top: -50px;
        left: -50px;
    }

    .circle2 {
        width: 250px;
        height: 250px;
        background: rgba(251,191,36,0.15);
        bottom: -50px;
        right: -50px;
    }
</style>

<div class="circle1"></div>
<div class="circle2"></div>

<div class="login-wrapper">

    <div class="glass-card">

        <div class="logo-title">
            EASYPI
        </div>

        <div class="subtitle">
            A Recipe System for beginners
        </div>

        <a asp-area="Identity"
           asp-page="/Account/Login"
           class="btn btn-login">

            Login

        </a>

    </div>

</div>