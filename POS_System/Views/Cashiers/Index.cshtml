@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject POS_System.Data.ApplicationDbContext DbContext
@{
    ViewData["Title"] = "Manage Cashiers";
}

<h2>Cashiers</h2>
<a asp-action="Create" class="btn btn-primary mb-3">+ Add Cashier</a>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Photo</th>
            <th>Full Name</th>
            <th>Username</th>
            <th>Email</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            var aspUser = await DbContext.Database
            .SqlQueryRaw<POS_System.Models.CashierInfo>(
                                    "SELECT FullName, ProfileImage FROM AspNetUsers WHERE Id = {0}", user.Id)
            .ToListAsync();

            var fullName = aspUser.FirstOrDefault()?.FullName ?? "N/A";
            var image = aspUser.FirstOrDefault()?.ProfileImage ?? "/images/default-avatar.png";

            <tr>
                <td>
                    <img src="@image" class="rounded-circle"
                         style="width:40px;height:40px;object-fit:cover;" />
                </td>
                <td>@fullName</td>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@user.Id"
                       class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@user.Id"
                       class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>