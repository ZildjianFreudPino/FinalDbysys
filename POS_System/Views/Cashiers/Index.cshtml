@model IEnumerable<POS_System.Models.ViewModel.CashierViewModel>
@{
    ViewData["Title"] = "Manage Cashiers";
    var searchTerm = ViewData["Search"]?.ToString();
}

<h2>Cashiers</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Create" class="btn btn-primary">+ Add Cashier</a>
    <form method="get" class="d-flex gap-2" style="min-width:300px;">
        <input type="text"
               name="search"
               value="@searchTerm"
               class="form-control"
               placeholder="Search by name, username or email..." />
        <button type="submit" class="btn btn-secondary">Search</button>
        @if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        }
    </form>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No cashiers found matching "<strong>@searchTerm</strong>".
    </div>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Photo</th>
                <th>Full Name</th>
                <th>Username</th>
                <th>Email</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>
                        <img src="@user.ProfileImage"
                             class="rounded-circle"
                             style="width:40px;height:40px;object-fit:cover;" />
                    </td>
                    <td>@(string.IsNullOrEmpty(user.FullName) ? "N/A" : user.FullName)</td>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@user.Id"
                           class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@user.Id"
                           class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}