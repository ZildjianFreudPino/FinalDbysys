@model POS_System.Models.Product

@{
    ViewData["Title"] = "Create Product";
}

<div class="product-page">

    <div class="product-card">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h1 class="page-title">Add Product</h1>
                <p class="page-subtitle">
                    Create a new product for your inventory.
                </p>
            </div>

        </div>

        <form asp-action="Create" enctype="multipart/form-data">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label asp-for="Name" class="form-label custom-label"></label>
                <input asp-for="Name"
                       class="form-control custom-input"
                       placeholder="Enter product name..." />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label custom-label"></label>
                <textarea asp-for="Description"
                          class="form-control custom-input"
                          rows="4"
                          placeholder="Enter product description..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">

                <div class="col-md-6 mb-4">
                    <label asp-for="Price" class="form-label custom-label"></label>
                    <input asp-for="Price"
                           class="form-control custom-input"
                           placeholder="0.00" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-4">
                    <label asp-for="Stock" class="form-label custom-label"></label>
                    <input asp-for="Stock"
                           class="form-control custom-input"
                           placeholder="Enter stock quantity..." />
                    <span asp-validation-for="Stock" class="text-danger"></span>
                </div>

            </div>

            <div class="mb-4">
                <label asp-for="CategoryId" class="form-label custom-label">
                    Category
                </label>

                <select asp-for="CategoryId"
                        class="form-select custom-input"
                        asp-items="ViewBag.CategoryId">

                    <option value="">-- Select Category --</option>

                </select>

                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="mb-5">
                <label class="form-label custom-label">
                    Product Image
                </label>

                <input type="file"
                       name="ImageFile"
                       class="form-control custom-input" />
            </div>

            <div class="d-flex gap-3">

                <button type="submit" class="btn btn-save">
                    Create Product
                </button>

                <a asp-action="Index" class="btn btn-back">
                    Back
                </a>

            </div>

        </form>

    </div>

</div>

<style>

    .product-page {
        padding: 10px;
    }

    .product-card {
        background: white;
        border-radius: 30px;
        padding: 40px;
        max-width: 900px;
        box-shadow: 0 2px 10px rgba(0,0,0,.04);
    }

    .page-title {
        font-size: 34px;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 8px;
    }

    .page-subtitle {
        color: #64748b;
        font-size: 18px;
        margin-bottom: 35px;
    }

    .custom-label {
        font-size: 16px;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 10px;
    }

    .custom-input {
        height: 58px;
        border-radius: 18px;
        border: 1px solid #dbe2ea;
        font-size: 16px;
        padding-left: 18px;
        box-shadow: none !important;
    }

        .custom-input:focus {
            border-color: #cbd5e1;
            box-shadow: none;
        }

    textarea.custom-input {
        height: 150px;
        padding-top: 16px;
        resize: none;
    }

    .btn-save {
        background: #16a34a;
        color: white;
        border-radius: 18px;
        padding: 14px 30px;
        font-size: 16px;
        font-weight: 700;
        border: none;
    }

        .btn-save:hover {
            background: #15803d;
            color: white;
        }

    .btn-back {
        border-radius: 18px;
        padding: 14px 30px;
        font-size: 16px;
        font-weight: 700;
        border: 1px solid #cbd5e1;
        color: #475569;
        background: white;
    }

        .btn-back:hover {
            background: #f8fafc;
        }

</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}