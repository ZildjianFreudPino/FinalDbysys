@model IEnumerable<POS_System.Models.Product>

@{
    ViewData["Title"] = "Products";
    var searchTerm = ViewData["Search"]?.ToString();
}

<style>

    
    body {
        overflow: hidden;
        background: #f5f6fa;
        font-family: 'Inter', sans-serif;
    }

    .page-title {
        font-size: 32px;
        font-weight: 700;
        color: #1f2937;
    }

    .product-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 2px 10px rgba(0,0,0,.04);
    }

    .search-box {
        border-radius: 14px;
        height: 52px;
        border: 1px solid #dbe0e6;
        padding-left: 18px;
        font-size: 16px;
    }

    .btn-add {
        background: #16a34a;
        color: white;
        border: none;
        border-radius: 14px;
        padding: 12px 22px;
        font-weight: 600;
    }

        .btn-add:hover {
            background: #15803d;
            color: white;
        }

    .table {
        margin-top: 20px;
        vertical-align: middle;
    }

        .table thead th {
            border: none;
            color: #6b7280;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            padding: 18px;
        }

        .table tbody td {
            padding: 18px;
            border-color: #eef1f5;
            vertical-align: middle;
        }

    .product-img {
        width: 65px;
        height: 65px;
        object-fit: cover;
        border-radius: 14px;
    }

    .product-name {
        font-weight: 700;
        color: #111827;
    }

    .price {
        font-weight: 700;
    }

    .action-btn {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        border: none;
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-right: 5px;
    }

    .btn-edit {
        background: #2563eb;
    }

    .btn-details {
        background: #06b6d4;
    }

    .btn-delete {
        background: #ef4444;
    }

    .empty-box {
        background: white;
        padding: 30px;
        border-radius: 20px;
        text-align: center;
        color: #6b7280;
    }

</style>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">


<div class="product-card mt-0">
    <div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h1 class="page-title mb-0">Products</h1>

        <p class="text-muted mb-0">
            Manage your products and inventory.
        </p>
    </div>

        <a asp-action="Create"
           class="btn btn-success d-flex align-items-center gap-2 px-4 py-2 rounded-4">

            <span class="material-symbols-outlined m-0">
                add
            </span>

            <span>Add Product</span>

        </a>

</div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <form method="get" class="d-flex gap-2 align-items-center" style="width:500px;">

            <input type="text"
                   name="search"
                   value="@searchTerm"
                   class="form-control search-box"
                   placeholder="Search products..." />

            <button type="submit"
                    class="btn btn-dark px-4 rounded-4">
                Search
            </button>

            <button type="button"
                    class="btn btn-light border rounded-4 px-3"
                    onclick="location.href='@Url.Action("Index")'">

                <span class="material-symbols-outlined">
                    refresh
                </span>

            </button>

        </form>
        

        </div>
@if (TempData["Error"] != null)
{
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
}

@if (TempData["Success"] != null)
{
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
}

        @if (!Model.Any())
        {
            <div class="empty-box">
                No products found.
            </div>
        }
else
{
        <div style="height: calc(100vh - 420px); overflow-y: auto; overflow-x: hidden;">
            <table class="table align-middle">

                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Product Name</th>
                        <th>Description</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Category</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @if (!string.IsNullOrEmpty(item.ImagePath))
                                {
                                    <img src="@item.ImagePath"
                                         class="product-img" />
                                }
                                else
                                {
                                    <div class="text-muted small">
                                        No image
                                    </div>
                                }
                            </td>

                            <td class="product-name">
                                @item.Name
                            </td>

                            <td>
                                @item.Description
                            </td>

                            <td class="price">
                                ₱@item.Price.ToString("N2")
                            </td>

                            <td>
                                @item.Stock
                            </td>

                            <td>
                                @item.Category?.Name
                            </td>

                            <td class="text-center">

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="action-btn btn-edit text-decoration-none">

                                    <span class="material-symbols-outlined">
                                        edit
                                    </span>

                                </a>

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="action-btn btn-details text-decoration-none">

                                    <span class="material-symbols-outlined">
                                        visibility
                                    </span>

                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="action-btn btn-delete text-decoration-none">

                                    <span class="material-symbols-outlined">
                                        delete
                                    </span>

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
}
