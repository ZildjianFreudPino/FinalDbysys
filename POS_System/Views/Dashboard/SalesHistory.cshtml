@model List<POS_System.Models.ViewModels.SaleHistoryDto>

@{
    Layout = null;
    ViewData["Title"] = "Sales History";
    bool isAdmin = User.IsInRole("Admin");
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Sales History</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"
          rel="stylesheet" />

    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
          rel="stylesheet" />

    <style>

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f7f9ff;
            margin: 0;
        }

        .sidebar {
            min-width: 280px;
            max-width: 280px;
            min-height: 100vh;
        }

        .material-symbols-outlined {
            vertical-align: middle;
            font-size: 20px;
        }

    </style>

</head>

<body class="d-flex">

    <!-- Sidebar -->
    <aside class="sidebar bg-white border-end d-none d-md-flex flex-column sticky-top">

        <div class="p-4 border-bottom">

            <h1 class="h4 fw-bold text-warning mb-0">
                EASYPI POS
            </h1>

        </div>

        <nav class="flex-grow-1 p-3">

            <div class="nav flex-column nav-pills gap-2">

                <a class="nav-link text-dark d-flex align-items-center gap-3 py-3"
                   asp-controller="Dashboard"
                   asp-action="Index">

                    <span class="material-symbols-outlined">
                        dashboard
                    </span>

                    <span>Dashboard</span>

                </a>

                <a class="nav-link active bg-warning text-dark fw-bold d-flex align-items-center gap-3 py-3"
                   asp-controller="Dashboard"
                   asp-action="SalesHistory">

                    <span class="material-symbols-outlined">
                        history
                    </span>

                    <span>Sales History</span>

                </a>

                <a class="nav-link text-dark d-flex align-items-center gap-3 py-3"
                   asp-controller="Categories"
                   asp-action="Index">

                    <span class="material-symbols-outlined">
                        category
                    </span>

                    <span>Categories</span>

                </a>

                <a class="nav-link text-dark d-flex align-items-center gap-3 py-3"
                   asp-controller="Products"
                   asp-action="Index">

                    <span class="material-symbols-outlined">
                        inventory_2
                    </span>

                    <span>Products</span>

                </a>

                <a class="nav-link text-dark d-flex align-items-center gap-3 py-3"
                   asp-controller="Cashiers"
                   asp-action="Index">

                    <span class="material-symbols-outlined">
                        groups
                    </span>

                    <span>Cashiers</span>

                </a>

            </div>

        </nav>

        <div class="p-3 border-top mt-auto">

            <div class="d-flex align-items-center gap-3 px-2 py-2">

                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                     style="width:40px;height:40px;">

                    <span class="material-symbols-outlined">
                        person
                    </span>

                </div>

                <div class="d-flex flex-column">

                    <span class="small fw-bold">
                        @User.Identity?.Name
                    </span>

                    <span class="text-muted" style="font-size:0.75rem;">
                        Administrator
                    </span>

                </div>

            </div>

        </div>

    </aside>

    <!-- Main -->
    <main class="flex-grow-1 d-flex flex-column min-vh-100 overflow-hidden">

        <!-- Topbar -->
        <header class="navbar navbar-light bg-white border-bottom px-4 py-3 sticky-top">

            <div class="container-fluid">

                <h2 class="h4 fw-bold text-primary mb-0">
                    Sales History
                </h2>

                <div class="d-flex align-items-center gap-2">

                    <a asp-controller="Dashboard"
                       asp-action="Index"
                       class="btn btn-warning d-flex align-items-center gap-2 px-4 py-2 fw-bold">

                        <span class="material-symbols-outlined">
                            dashboard
                        </span>

                        Dashboard

                    </a>

                    <form asp-area="Identity"
                          asp-page="/Account/Logout"
                          method="post">

                        <button type="submit"
                                class="btn btn-outline-danger d-flex align-items-center gap-2 px-4 py-2">

                            <span class="material-symbols-outlined">
                                logout
                            </span>

                            Logout

                        </button>

                    </form>

                </div>

            </div>

        </header>

        <!-- Content -->
        <div class="p-4 flex-grow-1 overflow-auto">

            <div class="container-fluid">

                <!-- Filter Bar -->
                <form method="get">

                    <section class="card border-0 shadow-sm mb-4">

                        <div class="card-body p-4">

                            <div class="row g-3 align-items-end">

                                <div class="col-md-3">

                                    <label class="form-label small text-uppercase text-muted fw-bold">
                                        Status
                                    </label>

                                    <select name="status" class="form-select">

                                        <option value="">All Status</option>

                                        <option value="Completed"
                                                selected="@(ViewBag.Status == "Completed")">
                                            Completed
                                        </option>

                                        <option value="Voided"
                                                selected="@(ViewBag.Status == "Voided")">
                                            Voided
                                        </option>

                                    </select>

                                </div>

                                <div class="col-md-3">

                                    <label class="form-label small text-uppercase text-muted fw-bold">
                                        From Date
                                    </label>

                                    <input type="date"
                                           name="from"
                                           value="@ViewBag.From"
                                           class="form-control" />

                                </div>

                                <div class="col-md-3">

                                    <label class="form-label small text-uppercase text-muted fw-bold">
                                        To Date
                                    </label>

                                    <input type="date"
                                           name="to"
                                           value="@ViewBag.To"
                                           class="form-control" />

                                </div>

                                <div class="col-md-3">

                                    <div class="d-flex gap-2">

                                        <button type="submit"
                                                class="btn btn-primary fw-bold flex-grow-1 d-flex align-items-center justify-content-center gap-2">

                                            <span class="material-symbols-outlined">
                                                filter_list
                                            </span>

                                            Filter

                                        </button>

                                        <a asp-action="History"
                                           class="btn btn-light border d-flex align-items-center justify-content-center">

                                            <span class="material-symbols-outlined">
                                                refresh
                                            </span>

                                        </a>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </section>

                </form>

                <!-- Table -->
                <section class="card border-0 shadow-sm overflow-hidden mb-4">

                    <div class="table-responsive">

                        <table class="table table-hover align-middle mb-0">

                            <thead class="table-light border-bottom">

                                <tr>

                                    <th class="p-3 small text-uppercase text-muted"># (ID)</th>
                                    <th class="p-3 small text-uppercase text-muted">Date</th>
                                    <th class="p-3 small text-uppercase text-muted text-end">Subtotal</th>
                                    <th class="p-3 small text-uppercase text-muted text-end">Discount</th>
                                    <th class="p-3 small text-uppercase text-muted text-end">Total</th>
                                    <th class="p-3 small text-uppercase text-muted">Payment</th>
                                    <th class="p-3 small text-uppercase text-muted">Status</th>
                                    <th class="p-3 small text-uppercase text-muted text-center">Actions</th>

                                </tr>

                            </thead>

                            <tbody class="border-top-0">

                                @if (Model == null || !Model.Any())
                                {
                                    <tr>
                                        <td colspan="8" class="text-center text-muted p-4">
                                            No sales found.
                                        </td>
                                    </tr>
                                }

                                @if (Model != null)
                                {
                                    foreach (var s in Model)
                                    {
                                        <tr>

                                            <td class="p-3">
                                                <span class="text-primary fw-bold">
                                                    INV-@s.SaleId
                                                </span>
                                            </td>

                                            <td class="p-3 small">
                                                @s.SaleDate.ToLocalTime().ToString("MM/dd/yyyy hh:mm tt")
                                            </td>

                                            <td class="p-3 small text-end">
                                                ₱@s.SubTotal.ToString("N2")
                                            </td>

                                            <td class="p-3 small text-end text-danger">
                                                -₱@s.DiscountAmt.ToString("N2")
                                            </td>

                                            <td class="p-3 small text-end fw-bold">
                                                ₱@s.TotalAmount.ToString("N2")
                                            </td>

                                            <td class="p-3">

                                                <span class="small d-flex align-items-center gap-1">

                                                    <span class="material-symbols-outlined fs-6">
                                                        payments
                                                    </span>

                                                    @s.PaymentMode

                                                </span>

                                            </td>

                                            <td class="p-3">

                                                <span class="badge rounded-pill @(s.SaleStatus == "Completed"
                                                                          ? "bg-success-subtle text-success"
                                                                          : "bg-secondary") px-3 py-2">

                                                    @s.SaleStatus

                                                </span>

                                            </td>

                                            <td class="p-3 text-center">

                                                <button class="btn btn-sm btn-outline-primary border-0"
                                                        onclick="viewDetail(@s.SaleId)">

                                                    <span class="material-symbols-outlined">
                                                        visibility
                                                    </span>

                                                </button>

                                                @if (isAdmin && s.SaleStatus == "Completed")
                                                {
                                                    <button class="btn btn-sm btn-outline-danger border-0"
                                                            onclick="voidSale(@s.SaleId)">

                                                        <span class="material-symbols-outlined">
                                                            delete
                                                        </span>

                                                    </button>
                                                }

                                            </td>

                                        </tr>
                                    }
                                }

                            </tbody>

                        </table>

                    </div>

                </section>

            </div>

        </div>

    </main>

    <!-- Detail Modal -->
    <div class="modal fade" id="detailModal" tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content">

                <div class="modal-header">

                    <h5 class="modal-title">
                        Sale Detail
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>

                </div>

                <div class="modal-body"
                     id="detailBody"
                     style="font-family:monospace;">
                </div>

                <div class="modal-footer">

                    <button class="btn btn-secondary"
                            data-bs-dismiss="modal">

                        Close

                    </button>

                    <button class="btn btn-outline-secondary"
                            onclick="window.print()">

                        <span class="material-symbols-outlined">
                            print
                        </span>

                        Print

                    </button>

                </div>

            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        async function viewDetail(id) {

            const res = await fetch(`/Sales/Detail/${id}`);
            const r = await res.json();

            const lines = r.lines.map(l =>

                `<tr>
                    <td>${l.productName}</td>
                    <td class="text-center">${l.qty}</td>
                    <td class="text-end">₱${l.price.toFixed(2)}</td>
                    <td class="text-end">₱${l.lineTotal.toFixed(2)}</td>
                 </tr>`

            ).join('');

            document.getElementById('detailBody').innerHTML = `

                <div class="text-center mb-2">

                    <strong>Sale #${r.saleId}</strong><br>

                    <small>${new Date(r.saleDate).toLocaleString()}</small>

                </div>

                <table class="table table-sm">

                    <thead>

                        <tr>

                            <th>Item</th>
                            <th class="text-center">Qty</th>
                            <th class="text-end">Price</th>
                            <th class="text-end">Total</th>

                        </tr>

                    </thead>

                    <tbody>${lines}</tbody>

                </table>

                <hr>

                <div class="d-flex justify-content-between">
                    <span>Subtotal</span>
                    <strong>₱${r.subTotal.toFixed(2)}</strong>
                </div>

                <div class="d-flex justify-content-between text-danger">
                    <span>Discount (${r.discountPct}%)</span>
                    <strong>-₱${r.discountAmt.toFixed(2)}</strong>
                </div>

                <div class="d-flex justify-content-between fw-bold fs-6 border-top pt-1">
                    <span>TOTAL</span>
                    <span>₱${r.totalAmount.toFixed(2)}</span>
                </div>

            `;

            new bootstrap.Modal(document.getElementById('detailModal')).show();

        }

        async function voidSale(id) {

            if (!confirm(`Void Sale #${id}? This will restore stock.`))
                return;

            const res = await fetch(`/Sales/Void/${id}`, {
                method: 'POST'
            });

            const data = await res.json();

            if (res.ok) {

                alert(data.message);
                location.reload();

            } else {

                alert(data.error);

            }

        }

    </script>

</body>

</html>