@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var user = await UserManager.GetUserAsync(User);
}

<style>
    html, body {
        overflow: hidden;
    }

    .dashboard-scroll {
        max-height: calc(100vh - 180px);
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 4px;
    }

    .dashboard-card {
        border: none;
        border-radius: 24px;
        background: white;
        box-shadow: 0 2px 10px rgba(0,0,0,.04);
    }

    .stat-card {
        border-radius: 22px;
        background: white;
        padding: 24px;
        height: 100%;
    }

    .chart-bar {
        background: #dbe4ee;
        border-radius: 10px 10px 0 0;
    }

    .chart-bar.active {
        background: #facc15;
    }

    body {
        overflow-x: hidden;
    }

    .main-content {
        overflow-x: hidden;
    }

    .container-fluid {
        overflow-x: hidden;
    }
</style>

<div class="container-fluid px-4 py-4 overflow-hidden">
    <div class="dashboard-scroll">

        <!-- TOP STATS -->
        <div class="row g-4 mb-4">

            <div class="col-md-4">

                <div class="stat-card">

                    <div class="d-flex justify-content-between mb-2">

                        <span class="text-secondary small fw-semibold">
                            TOTAL SALES
                        </span>

                        <span class="text-success fw-bold small">
                            +12.4%
                        </span>

                    </div>

                    <h2 class="fw-bold">₱14,285.50</h2>

                    <div class="progress mt-3" style="height:6px;">
                        <div class="progress-bar bg-warning" style="width:75%"></div>
                    </div>

                </div>

            </div>

            <div class="col-md-4">

                <div class="stat-card">

                    <div class="d-flex justify-content-between mb-2">

                        <span class="text-secondary small fw-semibold">
                            TRANSACTIONS
                        </span>

                        <span class="text-success fw-bold small">
                            +5.2%
                        </span>

                    </div>

                    <h2 class="fw-bold">142</h2>

                    <small class="text-secondary">
                        vs. 135 yesterday
                    </small>

                </div>

            </div>

            <div class="col-md-4">

                <div class="stat-card">

                    <div class="d-flex justify-content-between mb-2">

                        <span class="text-secondary small fw-semibold">
                            AVG ORDER VALUE
                        </span>

                        <span class="text-danger fw-bold small">
                            -2.1%
                        </span>

                    </div>

                    <h2 class="fw-bold">₱100.60</h2>

                    <small class="text-secondary">
                        Target: ₱110.00
                    </small>

                </div>

            </div>

        </div>

        <!-- TABLE + ACTIONS -->
        <div class="row g-4">

            <div class="col-xl-9">

                <div class="dashboard-card">

                    <div class="p-4 d-flex justify-content-between align-items-center">

                        <h5 class="fw-bold mb-0">
                            Recent Transactions
                        </h5>

                        <a href="#" class="text-decoration-none fw-bold">
                            VIEW ALL
                        </a>

                    </div>

                    <div class="table-responsive">

                        <table class="table align-middle mb-0">

                            <thead class="table-light">

                                <tr>
                                    <th class="px-4 py-3">ID</th>
                                    <th>Time</th>
                                    <th>Method</th>
                                    <th class="text-end px-4">Amount</th>
                                </tr>

                            </thead>

                            <tbody>

                                <tr>
                                    <td class="px-4">#TRX-94821</td>
                                    <td>2:22 PM</td>
                                    <td>
                                        <span class="badge bg-info-subtle text-info">
                                            CREDIT CARD
                                        </span>
                                    </td>
                                    <td class="text-end px-4 fw-bold">
                                        ₱1,240.00
                                    </td>
                                </tr>

                                <tr>
                                    <td class="px-4">#TRX-94822</td>
                                    <td>2:30 PM</td>
                                    <td>
                                        <span class="badge bg-warning-subtle text-warning">
                                            CASH
                                        </span>
                                    </td>
                                    <td class="text-end px-4 fw-bold">
                                        ₱540.00
                                    </td>
                                </tr>

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

            <div class="col-xl-3">

                <div class="dashboard-card p-4">

                    <h6 class="fw-bold mb-3">
                        Quick Actions
                    </h6>

                    <div class="d-grid gap-2">

                        <a asp-controller="Sales"
                           asp-action="Index"
                           class="btn btn-warning fw-bold">

                            New Sale

                        </a>

                        <button class="btn btn-outline-secondary">
                            Generate Report
                        </button>

                        <button class="btn btn-outline-secondary">
                            Manage Stock
                        </button>

                    </div>

                </div>

            </div>

        </div>

        <!-- CHART -->
        <div class="dashboard-card mt-4 p-4">

            <div class="d-flex justify-content-between align-items-center mb-4">

                <h5 class="fw-bold mb-0">
                    Weekly Sales Trend
                </h5>

                <div class="btn-group btn-group-sm">

                    <button class="btn btn-warning fw-bold">
                        Revenue
                    </button>

                    <button class="btn btn-outline-secondary">
                        Volume
                    </button>

                </div>

            </div>

            <div class="d-flex align-items-end justify-content-between gap-2"
                 style="height:250px;">

                <div class="flex-grow-1 chart-bar" style="height:40%;"></div>
                <div class="flex-grow-1 chart-bar" style="height:60%;"></div>
                <div class="flex-grow-1 chart-bar" style="height:75%;"></div>
                <div class="flex-grow-1 chart-bar" style="height:50%;"></div>
                <div class="flex-grow-1 chart-bar" style="height:90%;"></div>
                <div class="flex-grow-1 chart-bar active" style="height:100%;"></div>
                <div class="flex-grow-1 chart-bar" style="height:30%;"></div>

            </div>

        </div>

    </div>

</div>