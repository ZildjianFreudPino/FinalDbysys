@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Dashboard";
    Layout = null;

    var user = await UserManager.GetUserAsync(User);
}

<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>EASYPI - Dashboard</title>


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" rel="stylesheet" />

    <style>
        :root {
            --bs-body-bg: #f8f9fa;
            --brand-yellow: #facc15;
            --brand-yellow-hover: #eab308;
            --brand-dark: #0f172a;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bs-body-bg);
            color: #334155;
        }

        .material-symbols-outlined {
            vertical-align: middle;
            font-size: 1.25rem;
        }


        #sidebar {
            width: 280px;
            min-height: 100vh;
            background-color: white;
            border-right: 1px solid #e2e8f0;
        }

        .logo-text {
            color: var(--brand-yellow);
            font-weight: 700;
            font-size: 28px;
        }

        .nav-link {
            color: #64748b;
            padding: 12px 18px;
            border-radius: 10px;
            margin: 4px 12px;
            font-weight: 500;
            transition: .2s ease;
        }

            .nav-link:hover {
                background: #f1f5f9;
                color: black;
            }

            .nav-link.active {
                background: var(--brand-yellow);
                color: black !important;
            }


        .top-header {
            background: rgba(255,255,255,.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #e2e8f0;
            height: 80px;
        }


        .card {
            border: 1px solid #e2e8f0;
            border-radius: 18px;
            box-shadow: 0 2px 10px rgba(0,0,0,.04);
        }


        .btn-primary {
            background: var(--brand-yellow);
            border: none;
            color: black;
            font-weight: 600;
        }

            .btn-primary:hover {
                background: var(--brand-yellow-hover);
                color: black;
            }


        .chart-bar {
            background: #dbe4ee;
            border-radius: 6px 6px 0 0;
        }

            .chart-bar.active {
                background: var(--brand-yellow);
            }


        .table thead {
            background: #f8fafc;
        }


        .role-text {
            font-size: 11px;
            text-transform: uppercase;
            color: #94a3b8;
            font-weight: 600;
        }
    </style>
</head>

<body>

    <div class="container-fluid p-0 d-flex">


        <aside id="sidebar" class="d-none d-lg-flex flex-column sticky-top">

            <div class="p-4 border-bottom">
                <div class="logo-text">EASYPI</div>
            </div>

            <div class="flex-grow-1 py-3">

                <ul class="nav flex-column">

                    <li class="nav-item">
                        <a class="nav-link active d-flex align-items-center gap-2"
                           asp-controller="Dashboard"
                           asp-action="Index">

                            <span class="material-symbols-outlined">dashboard</span>
                            <span>Dashboard</span>

                        </a>
                    </li>

                    @if (User.IsInRole("Cashier"))
                    {
                        <li class="nav-item">

                            <a class="nav-link d-flex align-items-center gap-2"
                               asp-controller="Sales"
                               asp-action="Index">

                                <span class="material-symbols-outlined">
                                    point_of_sale
                                </span>

                                <span>POS</span>

                            </a>

                        </li>
                    }

                    <a class="nav-link d-flex align-items-center gap-2"
                       asp-controller="Dashboard"
                       asp-action="SalesHistory">

                        <span class="material-symbols-outlined">history</span>
                        <span>Sales History</span>

                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">

                            <a class="nav-link d-flex align-items-center gap-2"
                               asp-controller="Categories"
                               asp-action="Index">

                                <span class="material-symbols-outlined">
                                    category
                                </span>

                                <span>Categories</span>

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link d-flex align-items-center gap-2"
                               asp-controller="Products"
                               asp-action="Index">

                                <span class="material-symbols-outlined">
                                    inventory_2
                                </span>

                                <span>Products</span>

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link d-flex align-items-center gap-2"
                               asp-controller="Cashiers"
                               asp-action="Index">

                                <span class="material-symbols-outlined">
                                    groups
                                </span>

                                <span>Cashiers</span>

                            </a>

                        </li>
                    }

                </ul>

            </div>


            <div class="p-3 border-top mt-auto">

                <div class="d-flex align-items-center gap-3">

                    <img src="https://i.pravatar.cc/100"
                         width="45"
                         height="45"
                         class="rounded-circle border" />

                    <div class="overflow-hidden">

                        <div class="fw-bold text-truncate">
                            @user?.UserName
                        </div>

                        <div class="role-text">
                            Administrator
                        </div>

                    </div>

                </div>

            </div>

        </aside>


        <main class="flex-grow-1 min-vh-100">


            <header class="top-header sticky-top px-4 d-flex align-items-center justify-content-between">

                <div>
                    <h4 class="fw-bold mb-0">Dashboard Overview</h4>

                    <small class="text-secondary">
                        Welcome to EASYPI POS System
                    </small>
                </div>

                <div class="d-flex align-items-center gap-3">

                    <button class="btn btn-light">

                        <span class="material-symbols-outlined">
                            notifications
                        </span>

                    </button>

                    <a asp-controller="Sales"
                       asp-action="Index"
                       class="btn btn-primary d-flex align-items-center gap-2">

                        <span class="material-symbols-outlined">
                            add
                        </span>

                        New Sale

                    </a>
                    
                    <form asp-area="Identity"
                          asp-page="/Account/Logout"
                          asp-route-returnUrl="/Identity/Account/Login"
                          method="post">

                        <button type="submit"
                                class="btn btn-outline-danger d-flex align-items-center gap-2">

                            <span class="material-symbols-outlined">
                                logout
                            </span>

                            Logout

                        </button>

                    </form>

                </div>

            </header>


            <div class="container-fluid p-4">


                <div class="row g-4 mb-4">

                    <div class="col-md-4">

                        <div class="card p-4">

                            <div class="d-flex justify-content-between mb-2">

                                <span class="text-secondary small fw-semibold">
                                    TOTAL SALES
                                </span>

                                <span class="text-success fw-bold small">
                                    +12.4%
                                </span>

                            </div>

                            <h2 class="fw-bold">$14,285.50</h2>

                            <div class="progress mt-3" style="height:6px;">
                                <div class="progress-bar bg-warning" style="width:75%"></div>
                            </div>

                        </div>

                    </div>

                    <div class="col-md-4">

                        <div class="card p-4">

                            <div class="d-flex justify-content-between mb-2">

                                <span class="text-secondary small fw-semibold">
                                    TRANSACTIONS
                                </span>

                                <span class="text-success fw-bold small">
                                    +5.2%
                                </span>

                            </div>

                            <h2 class="fw-bold">142</h2>

                            <small class="text-secondary">
                                vs. 135 yesterday
                            </small>

                        </div>

                    </div>

                    <div class="col-md-4">

                        <div class="card p-4">

                            <div class="d-flex justify-content-between mb-2">

                                <span class="text-secondary small fw-semibold">
                                    AVG ORDER VALUE
                                </span>

                                <span class="text-danger fw-bold small">
                                    -2.1%
                                </span>

                            </div>

                            <h2 class="fw-bold">$100.60</h2>

                            <small class="text-secondary">
                                Target: $110.00
                            </small>

                        </div>

                    </div>

                </div>


                <div class="row g-4">

                    <div class="col-xl-9">

                        <div class="card">

                            <div class="card-header bg-white border-0 p-4 d-flex justify-content-between align-items-center">

                                <h5 class="fw-bold mb-0">
                                    Recent Transactions
                                </h5>

                                <a href="#" class="text-decoration-none fw-bold">
                                    VIEW ALL
                                </a>

                            </div>

                            <div class="table-responsive">

                                <table class="table table-hover align-middle mb-0">

                                    <thead>

                                        <tr>
                                            <th class="px-4 py-3">ID</th>
                                            <th>Time</th>
                                            <th>Method</th>
                                            <th class="text-end px-4">Amount</th>
                                        </tr>

                                    </thead>

                                    <tbody>

                                        <tr>
                                            <td class="px-4">#TRX-94821</td>
                                            <td>2:22 PM</td>
                                            <td>
                                                <span class="badge bg-info-subtle text-info">
                                                    CREDIT CARD
                                                </span>
                                            </td>
                                            <td class="text-end px-4 fw-bold">
                                                $1,240.00
                                            </td>
                                        </tr>

                                        <tr>
                                            <td class="px-4">#TRX-94822</td>
                                            <td>2:30 PM</td>
                                            <td>
                                                <span class="badge bg-warning-subtle text-warning">
                                                    CASH
                                                </span>
                                            </td>
                                            <td class="text-end px-4 fw-bold">
                                                $540.00
                                            </td>
                                        </tr>

                                    </tbody>

                                </table>

                            </div>

                        </div>

                    </div>


                    <div class="col-xl-3">

                        <div class="card p-4">

                            <h6 class="fw-bold mb-3">
                                Quick Actions
                            </h6>

                            <div class="d-grid gap-2">

                                <a asp-controller="Sales"
                                   asp-action="Index"
                                   class="btn btn-primary d-flex align-items-center justify-content-center gap-2">

                                    <span class="material-symbols-outlined">
                                        add
                                    </span>

                                    New Sale

                                </a>

                                <button class="btn btn-outline-secondary">
                                    Generate Report
                                </button>

                                <button class="btn btn-outline-secondary">
                                    Manage Stock
                                </button>

                            </div>

                        </div>

                    </div>

                </div>


                <div class="card mt-4 p-4">

                    <div class="d-flex justify-content-between align-items-center mb-4">

                        <h5 class="fw-bold mb-0">
                            Weekly Sales Trend
                        </h5>

                        <div class="btn-group btn-group-sm">

                            <button class="btn btn-primary">
                                Revenue
                            </button>

                            <button class="btn btn-outline-secondary">
                                Volume
                            </button>

                        </div>

                    </div>

                    <div class="d-flex align-items-end justify-content-between gap-2"
                         style="height:250px;">

                        <div class="flex-grow-1 chart-bar" style="height:40%;"></div>
                        <div class="flex-grow-1 chart-bar" style="height:60%;"></div>
                        <div class="flex-grow-1 chart-bar" style="height:75%;"></div>
                        <div class="flex-grow-1 chart-bar" style="height:50%;"></div>
                        <div class="flex-grow-1 chart-bar" style="height:90%;"></div>
                        <div class="flex-grow-1 chart-bar active" style="height:100%;"></div>
                        <div class="flex-grow-1 chart-bar" style="height:30%;"></div>

                    </div>

                </div>

            </div>

        </main>

    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>