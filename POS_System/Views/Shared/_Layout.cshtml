@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EASYPI</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/POS_System.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@400" />
   
    <style>
        .account-section {
            margin-top: auto;
            width: 100%;
        }

        .user-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: #3b82f6;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 20px;
        }
        body {
            background-color: #f5f6fa;
            font-family: 'Inter', sans-serif;
        }

        .sidebar {
            width: 320px;
            height: 100vh;
            background: white;
            border-right: 1px solid #e5e7eb;
            display: flex;
            flex-direction: column;
            position: relative;
            height: 100vh;
        }

        .main-content {
            flex: 1;
            background: #f5f6fa;
        }

        .top-navbar {
            height: 80px;
            background: white;
            border-bottom: 1px solid #e5e7eb;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 20px;
            margin: 8px 14px;
            border-radius: 16px;
            color: #64748b;
            font-size: 18px;
            font-weight: 600;
            text-decoration: none;
            transition: .2s;
        }

            .nav-link:hover {
                background: #f3f4f6;
                color: #111827;
            }

            .nav-link.active {
                background: #facc15;
                color: #000;
            }

            .nav-link .material-symbols-outlined {
                font-size: 24px;
            }

        .material-symbols-outlined {
            font-size: 22px;
        }

        body {
            overflow: hidden;
        }

        .main-content {
            height: 100vh;
            overflow: hidden;
        }

        .sidebar {
            width: 320px;
            height: 100vh;
            background: white;
            border-right: 1px solid #e5e7eb;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .account-section {
           
        }
        .container-fluid {
            height: calc(100vh - 80px);
            overflow-y: auto;
        }
    </style>
    
</head>

    <body>

        @if (ViewContext.RouteData.Values["Controller"]?.ToString() != "Home" &&
                !(ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("/Account/Login") ?? false))
        {

            <div class="d-flex">

                <!-- Sidebar -->
                <aside class="sidebar d-flex flex-column">

                    <div class="p-4 border-bottom">
                        <h2 style="font-weight:700; color:#f4b400;">
                            EASYPI POS
                        </h2>
                    </div>

                <nav class="nav flex-column py-3 flex-grow-1">
                    @{
                            var controller = ViewContext.RouteData.Values["controller"]?.ToString();
                        }

                    <a class="nav-link @(controller == "Dashboard" && action == "Index" ? "active" : "")" asp-controller="Dashboard"
                           asp-action="Index">
                            <span class="material-symbols-outlined">dashboard</span>
                            <span>Dashboard</span>
                        </a>

                    <a class="nav-link @(controller == "Dashboard" && action == "SalesHistory" ? "active" : "")"
                       asp-controller="Dashboard"
                       asp-action="SalesHistory">

                        <span class="material-symbols-outlined">history</span>
                        <span>Sales History</span>

                    </a>

                        <a class="nav-link @(controller == "Categories" ? "active" : "")"
                           asp-controller="Categories"
                           asp-action="Index">
                            <span class="material-symbols-outlined">category</span>
                            <span>Categories</span>
                        </a>

                        <a class="nav-link @(controller == "Products" ? "active" : "")"
                           asp-controller="Products"
                           asp-action="Index">
                            <span class="material-symbols-outlined">inventory_2</span>
                            <span>Products</span>
                        </a>
                    <a class="nav-link @(
                       controller == "Cashiers" ||
                       (ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("Register") ?? false)
                       ? "active" : "")"
                       asp-controller="Cashiers"
                       asp-action="Index">

                        <span class="material-symbols-outlined">groups</span>
                        <span>Cashiers</span>

                    </a>
                    </nav>

                    <!-- User -->
                <!-- User -->
                <div class="account-section d-flex align-items-center gap-3 p-3 border-top bg-light">

                    <div class="user-avatar">
                        @(User.Identity?.Name?.Substring(0, 1).ToUpper())
                    </div>

                    <div>
                        <div class="fw-bold">
                            @User.Identity?.Name
                        </div>

                        <div class="small text-secondary">
                            @(User.IsInRole("Admin") ? "Administrator" : "Cashier")
                        </div>
                    </div>

                </div>

                </aside>

                <!-- Main -->
                <main class="main-content flex-grow-1">

                    <!-- Topbar -->
                    <header class="top-navbar px-4 d-flex align-items-center justify-content-end">

    <form asp-area="Identity"
          asp-page="/Account/Logout"
          asp-route-returnUrl="/Identity/Account/Login"
          method="post"
          onsubmit="return confirm('Are you sure you want to logout?');">

        <button type="submit" class="btn btn-outline-danger">
            Logout
        </button>

    </form>

</header>

                    <!-- Body -->
                    <div class="container-fluid p-4">

                        @RenderBody()

                    </div>

                </main>

            </div>
        }
        else
        {
            @RenderBody()
        }

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>

        @await RenderSectionAsync("Scripts", required: false)

    </body>
</html>
