@page
@model RegisterModel
@{
    ViewData["Title"] = "Register Cashier";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        overflow-y: auto;
        overflow-x: hidden;
    }

    .cashier-container {
        padding: 30px;
    }

    .cashier-card {
        background: white;
        border-radius: 28px;
        padding: 40px;
        max-width: 720px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    }

    .cashier-title {
        font-size: 42px;
        font-weight: 800;
        color: #1e293b;
        line-height: 1;
        margin-bottom: 12px;
    }

    .cashier-subtitle {
        font-size: 16px;
        color: #64748b;
        margin-bottom: 35px;
    }

    .form-label {
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 10px;
    }

    .form-control {
        height: 60px;
        border-radius: 18px;
        border: 1px solid #dbe2ea;
        padding-left: 20px;
        font-size: 18px;
        box-shadow: none !important;
    }

    .profile-upload {
        text-align: center;
        margin-bottom: 35px;
    }

    .profile-preview {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #e5e7eb;
        margin-bottom: 15px;
    }

    .upload-btn {
        border-radius: 14px;
        padding: 10px 20px;
        font-weight: 600;
    }

    .btn-register {
        background: #16a34a;
        color: white;
        border: none;
        border-radius: 18px;
        padding: 14px 28px;
        font-size: 18px;
        font-weight: 700;
    }

        .btn-register:hover {
            background: #15803d;
            color: white;
        }

    .btn-cancel {
        border-radius: 18px;
        padding: 14px 28px;
        font-size: 18px;
        font-weight: 700;
    }
</style>

<div class="cashier-container">

    <div class="cashier-card">

        <div class="cashier-title">
            Add Cashier
        </div>

        <div class="cashier-subtitle">
            Create a new cashier account for your inventory system.
        </div>

        <form id="registerForm"
              asp-route-returnUrl="@Model.ReturnUrl"
              method="post"
              enctype="multipart/form-data">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3"></div>

            <div class="profile-upload">

                <img id="avatarPreview"
                     src="~/images/default-avatar.png"
                     class="profile-preview" />

                <div>
                    <label for="Input_ProfileImage"
                           class="btn btn-outline-secondary upload-btn">
                        Upload Photo
                    </label>

                    <input asp-for="Input.ProfileImage"
                           type="file"
                           id="Input_ProfileImage"
                           class="d-none"
                           accept="image/*"
                           onchange="previewImage(this)" />

                    <span asp-validation-for="Input.ProfileImage"
                          class="text-danger d-block mt-2"></span>
                </div>

            </div>

            <div class="mb-4">
                <label class="form-label">Username</label>

                <input asp-for="Input.UserName"
                       class="form-control"
                       placeholder="Enter username..." />

                <span asp-validation-for="Input.UserName"
                      class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label class="form-label">Full Name</label>

                <input asp-for="Input.FullName"
                       class="form-control"
                       placeholder="Enter full name..." />

                <span asp-validation-for="Input.FullName"
                      class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label class="form-label">Email</label>

                <input asp-for="Input.Email"
                       class="form-control"
                       placeholder="Enter email..." />

                <span asp-validation-for="Input.Email"
                      class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label class="form-label">Password</label>

                <input asp-for="Input.Password"
                       class="form-control"
                       placeholder="Enter password..." />

                <span asp-validation-for="Input.Password"
                      class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label class="form-label">Confirm Password</label>

                <input asp-for="Input.ConfirmPassword"
                       class="form-control"
                       placeholder="Confirm password..." />

                <span asp-validation-for="Input.ConfirmPassword"
                      class="text-danger"></span>
            </div>

            <div class="d-flex gap-3 mt-4">

                <button id="registerSubmit"
                        type="submit"
                        class="btn btn-register">
                    Register Cashier
                </button>

                <a asp-controller="Cashiers"
                   asp-action="Index"
                   class="btn btn-outline-secondary btn-cancel">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();

                reader.onload = e => {
                    document.getElementById('avatarPreview').src = e.target.result;
                }

                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}