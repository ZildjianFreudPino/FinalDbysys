@page
@model LoginModel
@{
    ViewData["Title"] = "";
}

<style>
    body {
        background: #0f172a;
        color: white;
    }


    .login-box {
        background: #111827;
        padding: 50px;
        border-radius: 30px;
        box-shadow: 0 0 40px rgba(0,0,0,0.45);
        max-width: 550px;
    }

    h1, h2 {
        color: #f59e0b;
        font-weight: bold;
    }

    .form-control {
        background-color: #1f2937 !important;
        border: 1px solid #374151;
        color: white !important;
        border-radius: 12px;
        padding: 15px;
    }

        .form-control:focus {
            background-color: #1f2937 !important;
            color: white !important;
            border-color: #f59e0b;
            box-shadow: none;
        }

    input:-webkit-autofill,
    input:-webkit-autofill:hover,
    input:-webkit-autofill:focus,
    textarea:-webkit-autofill,
    select:-webkit-autofill {
        -webkit-text-fill-color: white;
        -webkit-box-shadow: 0 0 0px 1000px #1f2937 inset;
        transition: background-color 5000s ease-in-out 0s;

    }

        input:-webkit-autofill,
        input:-webkit-autofill:hover,
        input:-webkit-autofill:focus,
        input:-webkit-autofill:active {
            -webkit-box-shadow: 0 0 0 1000px #1f2937 inset !important;
            -webkit-text-fill-color: white !important;
            caret-color: white !important;
            border: 1px solid #f59e0b !important;
            transition: background-color 9999s ease-in-out 0s;
        }

    .btn-login {
        background: #f59e0b;
        border: none;
        color: black;
        font-weight: bold;
        border-radius: 12px;
        padding: 12px;
    }

        .btn-login:hover {
            background: #fbbf24;
        }

    a {
        color: #f59e0b;
    }

    .form-floating > .form-control {
        height: 60px !important;
        min-height: 60px !important;
        padding: 1.625rem 0.75rem 0.625rem !important;
        background-color: #1f2937 !important;
        color: white !important;
        border: 1px solid #374151;
        border-radius: 15px;
    }

    .form-floating > label {
        color: #9ca3af !important;
        background: transparent !important;
    }

    .form-floating > .form-control:focus {
        background-color: #1f2937 !important;
        color: white !important;
        border-color: #f59e0b;
        box-shadow: none;
    }

    .form-floating > .form-control:-webkit-autofill {
        -webkit-box-shadow: 0 0 0 1000px #1f2937 inset !important;
        -webkit-text-fill-color: white !important;
    }

    .form-floating > label::after {
        background-color: transparent !important;
    }
</style>
<h1>@ViewData["Title"]</h1>
<div class="row justify-content-center align-items-center vh-100">
    <div class="text-center mb-4">
        <h1 style="color:#f59e0b; font-size:70px; font-weight:bold;">
            EASYPI
        </h1>
    </div>
    <div class="col-md-5 login-box">
        <section>
            <form id="account" method="post">
                <h1 class="text-center mb-4">Welcome Back</h1>

                <p class="text-center text-light mb-4">
                    Login to continue to EASYPI
                </p>
                <hr />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.UserName" class="form-control" autocomplete="email" aria-required="true" placeholder=" " />
                    <label asp-for="Input.UserName" class="form-label">Username or Email</label>
                    <span asp-validation-for="Input.UserName" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder=" " />
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="checkbox mb-3">
                    <label asp-for="Input.RememberMe" class="form-label">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>
                <div>
                    <button id="login-submit"
                            type="submit"
                            class="w-100 btn btn-lg btn-login">
                        Log in
                    </button>
                </div>
                <div>
                    <p>
                        <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
                    </p>
                    <p>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register as a new user</a>
                    </p>
                    <p>
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
                    </p>
                </div>
            </form>
        </section>
    </div>
    